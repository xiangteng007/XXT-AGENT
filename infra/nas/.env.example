# NAS Data Plane — 環境變數範本
# cp .env.example .env  然後填入實際值

# ── Qdrant ────────────────────────────────────────────────
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=change-me-qdrant-secret

# ── Redis ─────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-secret

# ── MinIO ─────────────────────────────────────────────────
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=openclaw
MINIO_ROOT_PASSWORD=change-me-minio-secret

# ── PostgreSQL（profile:full 才啟動）─────────────────────
POSTGRES_PORT=5432
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=change-me-postgres-secret
POSTGRES_DB=openclaw
