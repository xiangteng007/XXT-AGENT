# Firebase Project
GCLOUD_PROJECT=your-firebase-project-id

# For local development with emulators
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FUNCTIONS_EMULATOR_HOST=127.0.0.1:5001

# LINE Configuration (for local testing only - production uses Secret Manager)
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# Notion Configuration (for local testing only - production uses Secret Manager)
NOTION_INTEGRATION_TOKEN=your-notion-integration-token
NOTION_DATABASE_ID=your-notion-database-id

# OpenClaw Gateway (S-01: CORS 環境變數化)
# 生產環境設定此變數以限制 CORS，逗號分隔
# CORS_ALLOWED_ORIGINS=https://xxt-agent-dashboard.vercel.app,https://xxt-frontend.vercel.app
# DEV_BYPASS_AUTH=true  # 僅開發環境有效，生產環境自動被忽略 (S-02)

# AI-02: Model Fallback Chain（主模型 → 降級模型 → 本地 Ollama）
# AI_PRIMARY_MODEL=gemini-2.5-flash
# AI_FALLBACK_MODEL=gemini-2.0-flash
# OLLAMA_L1_MODEL=qwen3:14b
