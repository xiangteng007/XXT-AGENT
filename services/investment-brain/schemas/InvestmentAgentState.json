{
  "$defs": {
    "BaseMessage": {
      "additionalProperties": true,
      "description": "Base abstract message class.\n\nMessages are the inputs and outputs of a chat model.\n\nExamples include [`HumanMessage`][langchain.messages.HumanMessage],\n[`AIMessage`][langchain.messages.AIMessage], and\n[`SystemMessage`][langchain.messages.SystemMessage].",
      "properties": {
        "content": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "additionalProperties": true,
                    "type": "object"
                  }
                ]
              },
              "type": "array"
            }
          ],
          "title": "Content"
        },
        "additional_kwargs": {
          "additionalProperties": true,
          "title": "Additional Kwargs",
          "type": "object"
        },
        "response_metadata": {
          "additionalProperties": true,
          "title": "Response Metadata",
          "type": "object"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id"
        }
      },
      "required": [
        "content",
        "type"
      ],
      "title": "BaseMessage",
      "type": "object"
    },
    "FusionContext": {
      "description": "Triple Fusion context from Event Fusion Engine.",
      "properties": {
        "market": {
          "additionalProperties": true,
          "title": "Market",
          "type": "object"
        },
        "news": {
          "additionalProperties": true,
          "title": "News",
          "type": "object"
        },
        "social": {
          "additionalProperties": true,
          "title": "Social",
          "type": "object"
        },
        "severity": {
          "title": "Severity",
          "type": "integer"
        },
        "direction": {
          "enum": [
            "positive",
            "negative"
