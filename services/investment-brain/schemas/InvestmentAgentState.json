          "title": "Data Quality",
          "type": "string"
        },
        "credibility_tiers": {
          "additionalProperties": true,
          "title": "Credibility Tiers",
          "type": "object"
        }
      },
      "title": "FusionContext",
      "type": "object"
    },
    "InvestmentAction": {
