  "description": "The shared state flowing through the LangGraph investment supervisor.\n\nEach node reads what it needs and writes its output section.\nThe supervisor routes between nodes based on the current step.",
  "properties": {
    "messages": {
      "items": {
        "$ref": "#/$defs/BaseMessage"
      },
      "title": "Messages",
      "type": "array"
    },
    "current_step": {
      "enum": [
        "analyze",
        "plan",
        "risk_check",
        "execute",
        "evaluate",
        "complete",
        "error"
      ],
      "title": "Current Step",
      "type": "string"
    },
    "error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
