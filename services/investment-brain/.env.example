# ── AI Gateway ─────────────────────────────────────────────
AI_GATEWAY_URL=http://localhost:8080
AI_GATEWAY_API_KEY=

# ── Event Fusion Engine ────────────────────────────────────
FUSION_ENGINE_URL=http://localhost:8080

# ── Trade Planner Worker ───────────────────────────────────
TRADE_PLANNER_URL=http://localhost:8080

# ── OpenClaw Gateway ───────────────────────────────────────
OPENCLAW_GATEWAY_URL=http://localhost:3100

# ── Simulation Engine ──────────────────────────────────────
SIMULATION_ENGINE_URL=http://localhost:8091

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Google Gemini (不直接使用 — 所有 LLM Token 經由 AI Gateway / Antigravity 額度) ──
# GOOGLE_AI_API_KEY=  # 不需要：已通過 AI Gateway 統一管理

# ── LangSmith 可觀測性 ────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=xxt-investment-brain

# ── 風控參數 ───────────────────────────────────────────────
MAX_SINGLE_POSITION_PCT=20
MAX_DAILY_LOSS_PCT=5
MAX_DRAWDOWN_PCT=15
DEFAULT_RISK_LEVEL=moderate

# ── 服務設定 ───────────────────────────────────────────────
PORT=8090
LOG_LEVEL=INFO
