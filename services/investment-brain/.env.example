# ── AI Gateway ─────────────────────────────────────────────
AI_GATEWAY_URL=http://localhost:8080
AI_GATEWAY_API_KEY=

# ── Event Fusion Engine ────────────────────────────────────
FUSION_ENGINE_URL=http://localhost:8080

# ── Trade Planner Worker ───────────────────────────────────
TRADE_PLANNER_URL=http://localhost:8080

# ── OpenClaw Gateway ───────────────────────────────────────
OPENCLAW_GATEWAY_URL=http://localhost:3100

# ── Simulation Engine ──────────────────────────────────────
SIMULATION_ENGINE_URL=http://localhost:8091

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── A-05: Service-to-Service Auth ──────────────────────────
# 生產必填：Gateway 與 Brain 之間的共享密鑰（隨機 32 字元以上）
# INTERNAL_SECRET=change-me-in-production-use-openssl-rand-hex-32
# ENVIRONMENT=production   # development(預設) 時跳過 secret 驗證

# ── Session Store ──────────────────────────────────────────
SESSION_TTL_SECONDS=86400   # Session 存活時間（秒），預設 24 小時

# ── Fugle Market Data ──────────────────────────────────────
# FUGLE_API_KEY=your-fugle-api-key
# FUGLE_API_SECRET=your-fugle-api-secret

# ── Google Gemini（不直接使用 — 所有 LLM Token 經由 AI Gateway 統一管理）──
# GOOGLE_AI_API_KEY=  # 不需要：已通過 AI Gateway 統一管理

# ── LangSmith 可觀測性 ────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=xxt-investment-brain

# ── 風控參數 ───────────────────────────────────────────────
MAX_SINGLE_POSITION_PCT=20    # 單一部位最大倉位比例（%）
MAX_DAILY_LOSS_PCT=5          # 每日最大虧損限制（%）
MAX_DRAWDOWN_PCT=15           # 最大回撤上限（%）
DEFAULT_RISK_LEVEL=moderate   # conservative | moderate | aggressive

# ── 服務設定 ───────────────────────────────────────────────
PORT=8090
LOG_LEVEL=INFO
