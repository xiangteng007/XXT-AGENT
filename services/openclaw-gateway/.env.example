# OpenClaw Gateway — 環境變數
# cp .env.example .env  填入實際值

# ── 基礎設定 ──────────────────────────────────────────────────
PORT=3100
DEPLOY_MODE=local          # local | production
NODE_ENV=development

# ── 認證（生產時必填）─────────────────────────────────────────
# DEV_BYPASS_AUTH=true  # 開發用，跳過 JWT 驗證

# Firebase Service Account（生產環境 Cloud Run 使用 Workload Identity，不需要 key）
# FIREBASE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# ── A-05: Service-to-Service Auth ────────────────────────────
# Gateway → Investment Brain 共享密鑰（與 Brain 端的 INTERNAL_SECRET 相同）
# 生產必填：openssl rand -hex 32
# INTERNAL_SECRET=change-me-in-production-use-openssl-rand-hex-32

# ── Investment Brain ──────────────────────────────────────────
INVESTMENT_BRAIN_URL=http://localhost:8090

# ── Local Runner（M4b: 連接 Ollama NAS）────────────────────────
LOCAL_RUNNER_BASE_URL=http://localhost:11434   # 或 http://nas-ip:11434
OLLAMA_TIMEOUT_MS=30000

# ── 本地模型選型（基於 RTX 4080 SUPER 16GB VRAM）──────────────
# L1 通用推理（qwen3:14b ~9GB VRAM, ~50 tok/s）
OLLAMA_L1_MODEL=qwen3:14b
# L1 程式碼推理（qwen3-coder:30b-a3b MoE ~13GB VRAM, ~30 tok/s）
OLLAMA_CODER_MODEL=qwen3-coder:30b-a3b
# VRAM 保留時間：'5m'=5分鐘後釋放, '0'=推理完即釋放, '-1'=永久保留
OLLAMA_KEEP_ALIVE=5m

# ── Context Store: Redis（M4b: 連接 NAS Redis）─────────────────
# A-04: 也用於 reconcile 分散式鎖（60s TTL + 每 15s renewal）
REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:your-redis-password@nas-ip:6379

# ── NAS 服務（透過 Cloudflare Tunnel）─────────────────────────
# QDRANT_URL=https://qdrant.your-domain.com
# QDRANT_API_KEY=your-qdrant-api-key

# ── OpenClaw 整合 ─────────────────────────────────────────────
# OPENCLAW_GATEWAY_URL=http://localhost:3100  # Functions emitting back to self (dev)

# ── Agent 設定目錄 ────────────────────────────────────────────
AGENTS_CONFIG_DIR=../../.agent/agents

# ── WebSocket ─────────────────────────────────────────────────
WS_HEARTBEAT_MS=25000

# ── NemoClaw Layer 2: Privacy Router ─────────────────────────
# true = 所有請求強制走本地 Ollama（最嚴格隱私模式）
# false（預設）= PRIVATE/INTERNAL 走本地，PUBLIC 走雲端
PRIVACY_ENFORCE_LOCAL=false
# false = 稽核記錄中 PRIVATE prompt 顯示 [REDACTED]（建議）
# true  = 顯示遮蔽版（星號），方便本地除錯
PRIVACY_LOG_REDACTED_PROMPTS=false

# ── CORS ──────────────────────────────────────────────────────
# 生產環境設定此變數以限制 CORS，逗號分隔
# CORS_ALLOWED_ORIGINS=https://xxt-agent-dashboard.vercel.app

# ── NemoClaw Layer 4: Taiwan Regulation RAG ──────────────────
# 建築法規本地 RAG service（P2 實作後啟用）
# REGULATION_RAG_URL=http://localhost:8092
