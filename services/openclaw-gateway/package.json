{
  "name": "@xxt-agent/openclaw-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw Gateway — WebSocket + REST + Proxy + Local Runner Circuit Breaker",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
