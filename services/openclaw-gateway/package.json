    "swagger-ui-express": "^5.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.5.10",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.1"
